generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  bankroll  Int      @default(1000)
  hands     Int      @default(0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  pushes    Int      @default(0)
  resets          Int      @default(0)
  totalIncome     Int      @default(0)
  blackjacks      Int      @default(0)
  trainingHands   Int      @default(0)
  trainingCorrect Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
